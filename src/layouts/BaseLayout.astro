---
import "@/styles/globals.css";
import "@fontsource/playfair-display/900.css";
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-mono";
import { ClientRouter } from "astro:transitions";
import geistSansFont from "@fontsource/geist-sans/files/geist-sans-latin-400-normal.woff2?url";
import playfairFont from "@fontsource/playfair-display/files/playfair-display-latin-900-normal.woff2?url";
import { Toaster } from "@/components/shared/Toaster";
import { siteConfig } from "@/data/site.config";
import { generatePersonSchema, generateWebSiteSchema } from "@/lib/schema";
import { type ArticleMeta, baseUrl } from "@/lib/seo";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: "website" | "article";
  articleMeta?: ArticleMeta;
  dateModified?: string;
  ogImageAlt?: string;
}

const {
  title = `${siteConfig.name} — Software engineer at Cloudflare, Vinext contributor`,
  description = siteConfig.seo.metaDescription,
  ogImage = `${baseUrl}/og-image.webp`,
  canonical = `${baseUrl}${Astro.url.pathname}`,
  ogType = "website",
  articleMeta,
  dateModified,
  ogImageAlt = `${siteConfig.name} — Software Engineer & Blogger`,
} = Astro.props;

const personSchema = generatePersonSchema();
const websiteSchema = generateWebSiteSchema();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Font Preloads -->
    <link rel="preload" href={playfairFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistSansFont} as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={siteConfig.name} />
    {articleMeta && (
      <>
        <meta property="article:published_time" content={articleMeta.publishedTime} />
        {articleMeta.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
        <meta property="article:author" content={articleMeta.author} />
        {articleMeta.articleSection && <meta property="article:section" content={articleMeta.articleSection} />}
        {articleMeta.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
        {articleMeta.tags && <meta name="keywords" content={articleMeta.tags.join(", ")} />}
      </>
    )}
    {dateModified && <meta property="article:modified_time" content={dateModified} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="twitter:creator" content="@divkix" />
    <meta name="twitter:site" content="@divkix" />

    <meta name="content-signal" content="ai-train=no, search=yes, ai-input=yes" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name}'s Blog`} href="/rss.xml" />

    <!-- Identity Verification (rel="me") -->
    {siteConfig.socials
      .filter((s) => s.label !== "Email")
      .map((social) => (
        <link rel="me" href={social.href} />
      ))
    }

    <meta name="author" content={siteConfig.name} />

    <link rel="dns-prefetch" href="https://analytics.divkix.me" />
    <link rel="preconnect" href="https://analytics.divkix.me" crossorigin />

    <ClientRouter />

    <script is:inline>
      // Get theme from localStorage or system preference
      function getThemePreference() {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      // Apply theme to document
      function applyTheme(doc = document) {
        const theme = getThemePreference();
        if (theme === 'dark') {
          doc.documentElement.classList.add('dark');
        } else {
          doc.documentElement.classList.remove('dark');
        }
      }

      applyTheme();

      if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }

      // Apply theme to incoming document BEFORE swap (prevents flash)
      document.addEventListener('astro:before-swap', (event) => {
        const theme = getThemePreference();
        if (theme === 'dark') {
          event.newDocument.documentElement.classList.add('dark');
        } else {
          event.newDocument.documentElement.classList.remove('dark');
        }
      });

      // Fallback: reapply theme after swap completes
      document.addEventListener('astro:after-swap', () => {
        applyTheme();
      });
    </script>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <script
      is:inline
      async
      src="https://analytics.divkix.me/s.js"
      data-website-id="c27cdff0-16e4-49c7-b4c8-6b229ef3fd83"
    ></script>
  </head>
  <body>
    <slot />

    <Toaster client:idle />

    <button
      type="button"
      id="scroll-to-top"
      class="scroll-to-top fixed bottom-4 right-4 z-50 p-3 bg-primary text-primary-foreground rounded-full shadow-lg opacity-0 pointer-events-none transition-opacity duration-300"
      aria-label="Scroll to top"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m18 15-6-6-6 6" />
      </svg>
    </button>

    <script is:inline>
      (function () {
        const btn = document.getElementById("scroll-to-top");
        if (!btn) return;

        function onScroll() {
          const show = window.scrollY > 500;
          btn.classList.toggle("opacity-0", !show);
          btn.classList.toggle("pointer-events-none", !show);
        }

        btn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
