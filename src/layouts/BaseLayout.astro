---
import "@/styles/globals.css";
import "@fontsource/instrument-serif";
import "@fontsource/geist-sans";
import "@fontsource/geist-mono";
import { ClientRouter } from "astro:transitions";
import geistSansFont from "@fontsource/geist-sans/files/geist-sans-latin-400-normal.woff2?url";
import instrumentSerifFont from "@fontsource/instrument-serif/files/instrument-serif-latin-400-normal.woff2?url";
import { Toaster } from "@/components/shared/Toaster";
import { siteConfig } from "@/data/site.config";
import { generatePersonSchema, generateWebSiteSchema } from "@/lib/schema";
import { type ArticleMeta, baseUrl } from "@/lib/seo";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: "website" | "article";
  articleMeta?: ArticleMeta;
}

const {
  title = `${siteConfig.name} | Software Engineer, DevTools & Infrastructure`,
  description = siteConfig.seo.metaDescription,
  ogImage = `${baseUrl}/og-image.webp`,
  canonical = `${baseUrl}${Astro.url.pathname}`,
  ogType = "website",
  articleMeta,
} = Astro.props;

const personSchema = generatePersonSchema();
const websiteSchema = generateWebSiteSchema();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Font Preloads -->
    <link rel="preload" href={instrumentSerifFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistSansFont} as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content={siteConfig.name} />
    {articleMeta && (
      <>
        <meta property="article:published_time" content={articleMeta.publishedTime} />
        {articleMeta.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
        <meta property="article:author" content={articleMeta.author} />
        {articleMeta.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:creator" content="@divkix" />
    <meta name="twitter:site" content="@divkix" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name}'s Blog`} href="/rss.xml" />

    <!-- Identity Verification (rel="me") -->
    {siteConfig.socials
      .filter((s) => s.label !== "Email")
      .map((social) => (
        <link rel="me" href={social.href} />
      ))
    }

    <meta name="author" content={siteConfig.name} />

    <link rel="dns-prefetch" href="https://analytics.divkix.me" />
    <link rel="preconnect" href="https://analytics.divkix.me" crossorigin />

    <ClientRouter />

    <script is:inline>
      // Get theme from localStorage or system preference
      function getThemePreference() {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      // Apply theme to document
      function applyTheme(doc = document) {
        const theme = getThemePreference();
        if (theme === 'dark') {
          doc.documentElement.classList.add('dark');
        } else {
          doc.documentElement.classList.remove('dark');
        }
      }

      applyTheme();

      if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }

      // Apply theme to incoming document BEFORE swap (prevents flash)
      document.addEventListener('astro:before-swap', (event) => {
        const theme = getThemePreference();
        if (theme === 'dark') {
          event.newDocument.documentElement.classList.add('dark');
        } else {
          event.newDocument.documentElement.classList.remove('dark');
        }
      });

      // Fallback: reapply theme after swap completes
      document.addEventListener('astro:after-swap', () => {
        applyTheme();
      });
    </script>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <script
      is:inline
      async
      src="https://analytics.divkix.me/s.js"
      data-website-id="c27cdff0-16e4-49c7-b4c8-6b229ef3fd83"
    ></script>
  </head>
  <body>
    <div class="dot-grid-bg" aria-hidden="true"></div>
    <div class="page-noise" aria-hidden="true"></div>

    <slot />

    <Toaster client:idle />
  </body>
</html>
