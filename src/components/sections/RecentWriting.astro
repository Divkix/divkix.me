---
import type { CollectionEntry } from "astro:content";
import { calculateReadingTime, formatDate } from "@/lib/utils";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
const [featured, ...rest] = posts;
---

<section id="writing" class="text-band min-w-0">
  <header class="space-y-(--space-sm) mb-(--space-lg)">
    <h2 class="font-display text-(length:--text-display-s) leading-[1.05] tracking-(--tracking-display) m-0">
      Recent writing
    </h2>
    <p class="prose-measure text-muted-foreground leading-relaxed text-base">
      Notes I wrote down so I'd stop forgetting them: shipping, edge platforms, and the tools I reach for when something breaks at 2am.
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p class="text-muted-foreground">No posts yet.</p>
    ) : (
      <div class="space-y-0">
        {featured && (
          <article class="border-t border-border pt-(--space-lg) pb-(--space-md) min-w-0">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 text-xs text-muted-foreground mb-(--space-sm)">
              <time datetime={featured.data.date} class="tabular-nums">
                {formatDate(featured.data.date)}
              </time>
              <span aria-hidden="true">·</span>
              <span class="tabular-nums">
                {calculateReadingTime(featured.body)} min read
              </span>
            </div>
            <h3 class="font-display text-2xl md:text-3xl leading-[1.08] m-0">
              <a
                href={`/blog/${featured.id}`}
                class="text-foreground hover:text-primary transition-colors link-underline-grow"
              >
                {featured.data.title}
              </a>
            </h3>
            {featured.data.excerpt && (
              <p class="mt-(--space-sm) text-base text-muted-foreground leading-relaxed max-w-prose">
                {featured.data.excerpt}
              </p>
            )}
          </article>
        )}

        {rest.length > 0 && (
          <ol class="list-none m-0 p-0">
            {rest.map((post) => (
              <li class="border-t border-border py-(--space-md)">
                <article class="grid gap-x-(--space-lg) gap-y-1 sm:grid-cols-[8.5rem_minmax(0,1fr)] sm:items-baseline min-w-0">
                  <time
                    datetime={post.data.date}
                    class="text-xs text-muted-foreground tabular-nums whitespace-nowrap"
                  >
                    {formatDate(post.data.date)}
                  </time>
                  <div class="min-w-0 space-y-1">
                    <h3 class="font-display text-lg md:text-xl leading-[1.15] m-0">
                      <a
                        href={`/blog/${post.id}`}
                        class="text-foreground hover:text-primary transition-colors link-underline-grow"
                      >
                        {post.data.title}
                      </a>
                    </h3>
                    <p class="m-0 text-xs text-muted-foreground tabular-nums">
                      {calculateReadingTime(post.body)} min read
                    </p>
                  </div>
                </article>
              </li>
            ))}
          </ol>
        )}
      </div>
    )
  }

  <p class="mt-(--space-lg)">
    <a href="/blog" class="text-sm text-primary link-underline-grow">
      All posts <span aria-hidden="true">→</span>
    </a>
  </p>
</section>
