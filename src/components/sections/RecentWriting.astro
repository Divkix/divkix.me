---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@/lib/utils";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<section id="writing" class="text-band min-w-0">
  <header class="space-y-3 mb-[var(--space-xl)]">
    <h2 class="font-display text-[length:var(--text-display-s)] leading-[1.05] tracking-[var(--tracking-display)]">
      Recent writing
    </h2>
    <p class="text-muted-foreground leading-relaxed max-w-prose text-base md:text-lg">
      Notes on shipping, edge platforms, and tools I reach for when something breaks at 2am.
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p class="text-muted-foreground">No posts yet.</p>
    ) : (
      <ol class="list-none m-0 p-0 space-y-0">
        {posts.map((post) => (
          <li class="border-t border-border py-[var(--space-lg)] first:border-t-0 first:pt-0">
            <article class="space-y-2 min-w-0">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <time
                  datetime={post.data.date}
                  class="text-xs text-muted-foreground tabular-nums uppercase tracking-[0.06em]"
                >
                  {formatDate(post.data.date)}
                </time>
                {post.data.featured && (
                  <span class="text-xs text-primary uppercase tracking-[0.08em]">
                    Featured
                  </span>
                )}
              </div>
              <h3 class="font-display text-xl md:text-2xl leading-[1.1]">
                <a
                  href={`/blog/${post.id}`}
                  class="text-foreground hover:text-primary transition-colors link-underline-grow"
                >
                  {post.data.title}
                </a>
              </h3>
              {post.data.excerpt && (
                <p class="text-base text-muted-foreground leading-relaxed line-clamp-2">
                  {post.data.excerpt}
                </p>
              )}
            </article>
          </li>
        ))}
      </ol>
    )
  }

  <p class="mt-[var(--space-lg)]">
    <a
      href="/blog"
      class="text-sm text-primary link-underline-grow whitespace-nowrap uppercase tracking-[0.06em]"
    >
      All posts →
    </a>
  </p>
</section>
