---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@/lib/utils";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<section id="writing" class="container mx-auto px-4 py-16 md:py-24 max-w-3xl">
  <header class="space-y-3 mb-10">
    <h2 class="font-display text-3xl md:text-4xl font-medium tracking-tight">
      Recent writing
    </h2>
    <p class="text-muted-foreground leading-relaxed max-w-prose">
      Notes on shipping, edge platforms, and tools I reach for when something breaks at 2am.
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p class="text-muted-foreground">No posts yet.</p>
    ) : (
      <ol class="list-none m-0 p-0 space-y-0">
        {posts.map((post) => (
          <li class="border-t border-border py-6 first:border-t-0 first:pt-0">
            <article class="space-y-2">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <time
                  datetime={post.data.date}
                  class="text-sm text-muted-foreground tabular-nums"
                >
                  {formatDate(post.data.date)}
                </time>
                {post.data.featured && (
                  <span class="text-xs text-primary uppercase tracking-wide">
                    Featured
                  </span>
                )}
              </div>
              <h3 class="font-display text-xl md:text-2xl font-medium leading-snug">
                <a
                  href={`/blog/${post.id}`}
                  class="text-foreground hover:text-primary transition-colors link-underline-grow"
                >
                  {post.data.title}
                </a>
              </h3>
              {post.data.excerpt && (
                <p class="text-base text-muted-foreground leading-relaxed line-clamp-2">
                  {post.data.excerpt}
                </p>
              )}
            </article>
          </li>
        ))}
      </ol>
    )
  }

  <p class="mt-8">
    <a
      href="/blog"
      class="text-base text-primary link-underline-grow whitespace-nowrap"
    >
      All posts →
    </a>
  </p>
</section>
