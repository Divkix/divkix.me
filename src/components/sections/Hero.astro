---
import SocialIcons from "@/components/shared/SocialIcons.astro";
import { siteConfig } from "@/data/site.config";

const currentYear = new Date().getFullYear();
---

<section id="hero" class="photo-fold">
  <figure class="m-0">
    <img
      src={siteConfig.authorImage}
      alt={`Portrait of ${siteConfig.name}`}
      width="1200"
      height="800"
      loading="eager"
    />
    <figcaption class="photo-caption">
      {siteConfig.location} · {currentYear}
    </figcaption>
  </figure>
</section>

<section class="text-fold space-y-6 min-w-0" aria-labelledby="hero-heading">
  <p class="mast-line">Software engineer · builder</p>

  <h1
    id="hero-heading"
    class="font-display text-[length:var(--text-display)] leading-[1.0] text-foreground min-w-0 overflow-wrap-anywhere"
  >
    {siteConfig.name}
    <span class="sr-only"> — Software Engineer and Builder</span>
  </h1>

  <p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-prose">
    {siteConfig.heroSummary}
  </p>

  <div class="flex flex-wrap gap-3 pt-2">
    <a href="#projects" class="btn-primary">
      See selected work
    </a>
    <a href="/blog" class="btn-secondary">
      Read recent writing
    </a>
  </div>

  <div class="pt-4">
    <SocialIcons size="sm" />
  </div>
</section>
