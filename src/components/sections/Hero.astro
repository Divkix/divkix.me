---
import SocialIcons from "@/components/shared/SocialIcons.astro";
import { siteConfig } from "@/data/site.config";
---

<section id="hero" class="text-band" aria-labelledby="hero-heading">
  <div class="grid gap-(--space-xl) md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] md:items-start min-w-0">
    <div class="min-w-0 space-y-(--space-md)">
      <p class="mast-line">Software engineer · Cloudflare · ASU</p>

      <h1
        id="hero-heading"
        class="font-display text-(length:--text-display) leading-[1.02] text-foreground min-w-0 overflow-wrap-anywhere m-0"
      >
        {siteConfig.name}
        <span class="sr-only"> — Software Engineer and Builder</span>
      </h1>

      <p class="prose-measure text-(length:--text-md) md:text-lg text-foreground/85 leading-relaxed">
        {siteConfig.heroSummary}
      </p>

      <p class="prose-measure text-base text-muted-foreground leading-relaxed">
        {siteConfig.heroProof}
      </p>

      <div class="flex flex-wrap items-center gap-x-3 gap-y-3 pt-(--space-xs)">
        <a href="/#projects" class="btn-primary">
          See selected work
        </a>
        <a href="/resume" class="btn-secondary">
          View resume
        </a>
        <a
          href="/blog"
          class="text-sm text-muted-foreground hover:text-foreground link-underline-grow transition-colors"
        >
          Recent writing
        </a>
      </div>

      <p
        class="flex flex-wrap items-baseline gap-x-(--space-md) gap-y-1 pt-(--space-xs) text-xs text-muted-foreground"
        aria-label="At-a-glance stats"
      >
        <span>
          <span class="text-foreground tabular-nums font-medium">{siteConfig.facts.impact}</span>
          {" "}users
        </span>
        <span class="text-border" aria-hidden="true">·</span>
        <span>
          <span class="text-foreground tabular-nums font-medium">{siteConfig.facts.projects}</span>
          {" "}projects
        </span>
        <span class="text-border" aria-hidden="true">·</span>
        <span>
          <span class="text-foreground tabular-nums font-medium">{siteConfig.facts.oss}</span>
          {" "}open source
        </span>
      </p>

      <div class="pt-(--space-2xs)">
        <SocialIcons size="sm" />
      </div>
    </div>

    <figure
      class="portrait-frame m-0 w-full max-w-[16rem] sm:max-w-[18rem] md:max-w-none justify-self-start md:justify-self-end md:sticky md:top-[calc(4.5rem+var(--space-md))]"
    >
      <img
        src={siteConfig.authorImage}
        alt={`Portrait of ${siteConfig.name}`}
        aria-describedby="hero-image-caption"
        class="w-full aspect-4/5 object-cover object-[center_22%]"
        width="480"
        height="600"
        loading="eager"
        decoding="async"
      />
      <figcaption id="hero-image-caption" class="sr-only">
        Portrait of {siteConfig.name}, software engineer in Tempe, Arizona
      </figcaption>
    </figure>
  </div>
</section>
