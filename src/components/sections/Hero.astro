---
import SocialIcons from "@/components/shared/SocialIcons.astro";
import { siteConfig } from "@/data/site.config";
---

<section id="hero" class="text-band" aria-labelledby="hero-heading">
  <div class="grid gap-[var(--space-xl)] md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] md:items-start min-w-0">
    <div class="min-w-0 space-y-[var(--space-md)]">
      <p class="mast-line">Software engineer · Cloudflare · ASU</p>

      <h1
        id="hero-heading"
        class="font-display text-[length:var(--text-display)] leading-[1.02] text-foreground min-w-0 overflow-wrap-anywhere m-0"
      >
        {siteConfig.name}
        <span class="sr-only"> — Software Engineer and Builder</span>
      </h1>

      <p class="prose-measure text-[length:var(--text-md)] md:text-lg text-foreground/85 leading-relaxed">
        {siteConfig.heroSummary}
      </p>

      <div class="flex flex-wrap gap-3 pt-[var(--space-xs)]">
        <a href="/#projects" class="btn-primary">
          See selected work
        </a>
        <a href="/resume" class="btn-secondary">
          View resume
        </a>
        <a href="/blog" class="btn-secondary">
          Read recent writing
        </a>
      </div>

      <div class="pt-[var(--space-2xs)]">
        <SocialIcons size="sm" />
      </div>
    </div>

    <figure
      class="portrait-frame m-0 w-full max-w-[16rem] sm:max-w-[18rem] md:max-w-none justify-self-start md:justify-self-end md:sticky md:top-[calc(4.5rem+var(--space-md))]"
    >
      <img
        src={siteConfig.authorImage}
        alt={`Portrait of ${siteConfig.name}, software engineer in Tempe, Arizona`}
        class="w-full aspect-[4/5] object-cover object-[center_22%]"
        width="480"
        height="600"
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
</section>
