---
import { siteConfig } from "@/data/site.config";

type Position = (typeof siteConfig.experience)[number]["positions"][number];
type Company = (typeof siteConfig.experience)[number];
type Education = (typeof siteConfig.education)[number];
---

<section id="experience" class="space-y-12 not-prose">
  <header class="space-y-3">
    <h2 class="font-display text-3xl font-medium tracking-tight">Experience</h2>
    <p class="text-muted-foreground leading-relaxed max-w-prose">
      Engineering roles, teaching, and internships — the full timeline.
    </p>
  </header>

  <div class="split-studio">
    <div class="split-studio-content min-w-0 space-y-4">
      <h3 class="font-display text-xl font-medium">Education</h3>
      {siteConfig.education.map((edu: Education) => (
        <div class="space-y-1 border-t border-border pt-4 first:border-t-0 first:pt-0">
          <p class="font-medium text-foreground">{edu.title}</p>
          <p class="text-sm text-muted-foreground">{edu.year}</p>
          {"focus" in edu && edu.focus && (
            <p class="text-sm text-muted-foreground">Focus: {edu.focus}</p>
          )}
          {"honors" in edu && edu.honors && (
            <p class="text-sm text-primary">{edu.honors}</p>
          )}
        </div>
      ))}
    </div>
    <div class="split-studio-proof min-w-0">
      <p class="text-muted-foreground leading-relaxed">
        MS (GPA 3.889) and BS in Computer Science from Arizona State University. Years of tutoring kept me honest about explaining hard ideas in plain language.
      </p>
    </div>
  </div>

  <div class="space-y-0">
    {siteConfig.experience.map((company: Company) => {
      const isCurrentRole = company.duration.includes("Present");
      return (
        <article class="border-t border-border pt-8 min-w-0">
          <div class="split-studio">
            <div class="split-studio-content min-w-0 space-y-2">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <h3 class="font-display text-xl md:text-2xl font-medium">{company.company}</h3>
                {isCurrentRole && (
                  <span class="text-xs uppercase tracking-wide text-primary">Current</span>
                )}
              </div>
              <p class="text-sm text-muted-foreground">{company.location}</p>
              <p class="text-sm text-muted-foreground">{company.duration}</p>
            </div>
            <div class="split-studio-proof space-y-6 min-w-0">
              {company.positions.map((position: Position) => (
                <div>
                  <div class="flex flex-wrap items-baseline justify-between gap-x-2 gap-y-1 mb-2">
                    <h4 class="font-medium text-foreground">{position.title}</h4>
                    <span class="text-sm text-muted-foreground">{position.year}</span>
                  </div>
                  <ul class="space-y-2 list-none m-0 p-0">
                    {position.highlights.map((highlight: string) => (
                      <li class="text-sm text-foreground/75 leading-relaxed">
                        {highlight}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </article>
      );
    })}
  </div>
</section>
