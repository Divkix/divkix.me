---
import { siteConfig } from "@/data/site.config";

const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: "Blog", href: "/blog" },
  { label: "About", href: "/about" },
  { label: "Privacy", href: "/privacy" },
  { label: "Contact", href: "/#contact" },
];
---

<footer class="border-t border-border mt-(--section-gap)">
  <div class="content-rail py-(--space-2xl) space-y-(--space-md)">
    <p class="font-display text-2xl md:text-3xl text-foreground leading-[1.05] tracking-(--tracking-display)">
      {siteConfig.name}
    </p>
    <p class="text-muted-foreground text-base max-w-prose leading-relaxed">
      Software engineer, builder, writer. Based in {siteConfig.location}.
    </p>
    <p class="text-sm text-muted-foreground flex flex-wrap gap-x-4 gap-y-2">
      {
        footerLinks.map((link) => (
          <a
            href={link.href}
            class="text-foreground link-underline-grow whitespace-nowrap uppercase tracking-[0.06em]"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`mailto:${siteConfig.email}`}
        class="text-foreground link-underline-grow whitespace-nowrap uppercase tracking-[0.06em]"
        aria-label={`Email ${siteConfig.email}`}
      >
        Email
      </a>
    </p>
    <p class="text-xs text-muted-foreground tracking-[0.04em]">
      &copy; {currentYear} <span aria-hidden="true">·</span> {siteConfig.location}
    </p>
  </div>
</footer>
