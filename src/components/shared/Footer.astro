---
import { siteConfig } from "@/data/site.config";

const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: "Blog", href: "/blog" },
  { label: "About", href: "/about" },
  { label: "Privacy", href: "/privacy" },
  { label: "Contact", href: "/#contact" },
];
---

<footer class="border-t border-border mt-[var(--section-gap)]">
  <div class="mx-auto px-[var(--page-gutter)] py-[var(--space-2xl)] max-w-4xl text-center space-y-[var(--space-md)]">
    <p class="font-display text-2xl md:text-3xl text-foreground leading-[1.05] tracking-[var(--tracking-display)]">
      {siteConfig.name}
    </p>
    <p class="text-muted-foreground text-base max-w-prose mx-auto leading-relaxed">
      Software engineer, builder, writer. Based in {siteConfig.location}.
    </p>
    <p class="text-sm text-muted-foreground flex flex-wrap justify-center gap-x-4 gap-y-2">
      {
        footerLinks.map((link) => (
          <a
            href={link.href}
            class="text-foreground link-underline-grow whitespace-nowrap uppercase tracking-[0.06em]"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="mailto:divkix@divkix.me"
        class="text-foreground link-underline-grow whitespace-nowrap uppercase tracking-[0.06em]"
      >
        Email
      </a>
    </p>
    <p class="text-xs text-muted-foreground tracking-[0.04em]">
      &copy; {currentYear} · {siteConfig.location}
    </p>
  </div>
</footer>
