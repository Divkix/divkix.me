---
import { siteConfig } from "@/data/site.config";
import SiteLayout from "@/layouts/SiteLayout.astro";
import {
  generateBreadcrumbSchema,
  generateProfilePageSchema,
} from "@/lib/schema";
import { baseUrl } from "@/lib/seo";

const pricingUrl = `${baseUrl}/pricing`;

const pricingPageSchema = generateProfilePageSchema(
  "Freelance Services & Pricing",
  `Services and pricing for ${siteConfig.name}`,
  pricingUrl,
  {
    datePublished: "2025-01-01",
    articleSection: "Services",
  },
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "Pricing", item: pricingUrl },
]);

const services = [
  {
    name: "Web Development",
    price: "Starting at $2,000 per project",
    description:
      "Full-stack web applications, APIs, and portfolio sites built with modern frameworks.",
  },
  {
    name: "Technical Consulting",
    price: "$150/hour",
    description:
      "Architecture reviews, technology selection, and engineering strategy sessions.",
  },
  {
    name: "Code Review & Audits",
    price: "$500 per project",
    description:
      "Security audits, performance analysis, and code quality assessments.",
  },
  {
    name: "SEO Optimization",
    price: "$1,000 per project",
    description:
      "Technical SEO, structured data, and content optimization for search engines.",
  },
  {
    name: "AI Integration",
    price: "Custom pricing",
    description:
      "LLM-powered features, AI agent workflows, and intelligent automation.",
  },
];
---

<SiteLayout
  title="Freelance Services & Pricing — Divanshu Chauhan"
  description={`Services and pricing for ${siteConfig.name}`}
  ogImage={`${baseUrl}/og/pricing.png`}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(pricingPageSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="text-band">
    <div class="space-y-[var(--space-xl)]">
      <!-- Header -->
      <div class="space-y-[var(--space-md)] text-center">
        <p class="mast-line">Services</p>
        <h1 class="font-display text-[length:var(--text-display)]">Pricing</h1>
        <p class="text-[length:var(--text-xl)] text-foreground/70">
          Services and rates for freelance work
        </p>
      </div>

      <!-- Services Grid -->
      <div class="grid gap-[var(--space-md)] md:grid-cols-2">
        {services.map((service) => (
          <div class="surface-raised p-[var(--space-lg)] space-y-[var(--space-md)]">
            <div class="space-y-[var(--space-xs)]">
              <h2 class="font-display text-[length:var(--text-xl)]">{service.name}</h2>
              <p class="text-[length:var(--text-lg)] font-bold text-primary">{service.price}</p>
            </div>
            <p class="text-foreground/70">{service.description}</p>
          </div>
        ))}
      </div>

      <!-- Download Link -->
      <div class="text-center">
        <a
          href="/pricing.md"
          class="inline-flex items-center gap-2 text-primary link-underline-grow"
          download
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" x2="12" y1="15" y2="3" />
          </svg>
          Download pricing.md
        </a>
      </div>

      <!-- Contact -->
      <div class="text-center space-y-[var(--space-md)] pt-[var(--space-lg)] border-t border-border">
        <p class="text-foreground/60">
          For project inquiries or custom quotes, reach out:
        </p>
        <div class="flex items-center justify-center gap-[var(--space-md)]">
          <a
            href={`mailto:${siteConfig.email}`}
            class="text-primary link-underline-grow"
          >
            {siteConfig.email}
          </a>
          <span class="text-foreground/40">·</span>
          <a href="/" class="text-primary link-underline-grow">divkix.me</a>
        </div>
      </div>
    </div>
  </div>
</SiteLayout>
