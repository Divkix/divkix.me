---
import ExperienceBentoStatic from "@/components/sections/experience/ExperienceBentoStatic.astro";
import { Skills } from "@/components/sections/skills";
import { siteConfig } from "@/data/site.config";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { generateBreadcrumbSchema, generateFAQPageSchema } from "@/lib/schema";
import { baseUrl } from "@/lib/seo";

const aboutUrl = `${baseUrl}/about`;

const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": aboutUrl,
  mainEntity: {
    "@id": `${baseUrl}/#author`,
  },
  name: `About ${siteConfig.name}`,
  description: siteConfig.seo.metaDescription,
  url: aboutUrl,
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "About", item: aboutUrl },
]);

const aboutFaqSchema = generateFAQPageSchema([...siteConfig.faq], aboutUrl);
---

<SiteLayout
  title={`About ${siteConfig.name} — Software Engineer & Builder`}
  description={siteConfig.seo.metaDescription}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutFaqSchema)} />

  <article class="container mx-auto px-4 py-16 md:py-24 max-w-6xl">
    <header class="space-y-6 mb-12 max-w-3xl">
      <h1 class="font-display text-4xl md:text-5xl font-medium tracking-tight leading-tight">
        About me
      </h1>
      <p class="text-xl text-muted-foreground leading-relaxed">
        {siteConfig.tagline}
      </p>
      <div class="accent-line" aria-hidden="true"></div>
    </header>

    <div class="max-w-3xl space-y-8 text-lg leading-relaxed text-foreground/85 mb-16">
      <figure class="m-0 float-none md:float-right md:ml-8 md:mb-4 max-w-[200px] border border-border p-2 bg-card">
        <img
          src={siteConfig.authorImage}
          alt={`Portrait of ${siteConfig.name}`}
          class="w-full aspect-square object-cover"
          loading="eager"
        />
      </figure>

      <p>
        {siteConfig.about}
      </p>

      <p>
        Recent work includes <a href="https://github.com/cloudflare/vinext" class="text-primary link-underline-grow">Vinext</a> at Cloudflare (Next.js on Vite for Workers), <a href="https://github.com/Divkix/Logwell" class="text-primary link-underline-grow">LogWell</a> for self-hosted logging, <a href="https://pickmyclass.app" class="text-primary link-underline-grow">PickMyClass</a> for ASU course tracking, <a href="https://clickfolio.me" class="text-primary link-underline-grow">Clickfolio</a> for AI portfolios on Workers, and <a href="https://github.com/Divkix/Alita_Robot" class="text-primary link-underline-grow">Alita Robot</a> for Telegram communities ({siteConfig.facts.impact} users).
      </p>

      <p>
        I mostly work in TypeScript, Go, and Python. Cloudflare Workers, PostgreSQL, Docker, edge-native architectures. I like clean APIs, boring reliability, and software people actually use.
      </p>

      <h2 class="font-display text-2xl font-medium text-foreground pt-4">Outside of code</h2>
      <p class="text-base text-muted-foreground">
        {siteConfig.interests}
      </p>

      <h2 class="font-display text-2xl font-medium text-foreground pt-4">Open to work</h2>
      <p class="text-base">
        Full-time software engineering roles (backend, infrastructure, developer tools, AI tooling) starting May/June 2026. Open to relocation and remote.
      </p>

      <p class="text-base text-muted-foreground">
        {siteConfig.location} · <a href={`mailto:${siteConfig.email}`} class="text-primary link-underline-grow">{siteConfig.email}</a>
      </p>

      <div class="flex flex-wrap gap-3 pt-2 not-prose">
        {siteConfig.socials.map((social) => {
          const isEmail = social.label === "Email";
          return (
            <a
              href={social.href}
              target={isEmail ? undefined : "_blank"}
              rel={isEmail ? undefined : "me noopener noreferrer"}
              class="text-sm px-4 py-2 border border-border rounded-[var(--radius-input)] hover:border-primary hover:text-primary transition-colors whitespace-nowrap"
            >
              {social.label}
            </a>
          );
        })}
      </div>
    </div>

    <hr class="hairline-rule mb-16" />

    <ExperienceBentoStatic />

    <div class="mt-16">
      <Skills client:visible />
    </div>
  </article>
</SiteLayout>
