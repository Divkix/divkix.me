---
import ExperienceBentoStatic from "@/components/sections/experience/ExperienceBentoStatic.astro";
import { Skills } from "@/components/sections/skills";
import SocialIcons from "@/components/shared/SocialIcons.astro";
import { siteConfig } from "@/data/site.config";
import SiteLayout from "@/layouts/SiteLayout.astro";
import {
  generateBreadcrumbSchema,
  generateFAQPageSchema,
  generateProfilePageSchema,
} from "@/lib/schema";
import { baseUrl } from "@/lib/seo";

const aboutUrl = `${baseUrl}/about`;

const aboutPageSchema = generateProfilePageSchema(
  `About ${siteConfig.name}`,
  siteConfig.seo.metaDescription,
  aboutUrl,
  {
    datePublished: "2025-01-01",
    dateModified: "2026-05-20",
    articleSection: "About",
  },
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "About", item: aboutUrl },
]);

const aboutFaqSchema = generateFAQPageSchema([...siteConfig.faq], aboutUrl);
---

<SiteLayout
  title={`About Divanshu Chauhan — Cloudflare engineer, Vinext contributor`}
  description={siteConfig.seo.metaDescription}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutFaqSchema)} />

  <article class="min-w-0">
    <section class="text-band" aria-labelledby="about-heading">
      <p class="mast-line mb-[var(--space-sm)]">About</p>

      <div
        class="grid gap-[var(--space-xl)] md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] md:items-start min-w-0"
      >
        <header class="min-w-0 space-y-[var(--space-md)]">
          <h1
            id="about-heading"
            class="font-display text-[length:var(--text-display-s)] leading-[1.05] text-foreground min-w-0 overflow-wrap-anywhere m-0"
          >
            {siteConfig.name}
          </h1>
          <p class="prose-measure text-[length:var(--text-md)] md:text-lg text-foreground/85 leading-relaxed">
            {siteConfig.tagline}
          </p>
          <p class="text-xs text-muted-foreground uppercase tracking-[0.18em]">
            {siteConfig.location} ·
            <a
              href={`mailto:${siteConfig.email}`}
              class="link-underline-grow"
              rel="me author"
            >
              {siteConfig.email}
            </a>
          </p>
        </header>

        <figure
          class="portrait-frame m-0 w-full max-w-[16rem] sm:max-w-[18rem] md:max-w-none justify-self-start md:justify-self-end md:sticky md:top-[calc(4.5rem+var(--space-md))]"
        >
          <img
            src={siteConfig.authorImage}
            alt={`Portrait of ${siteConfig.name}, software engineer in Tempe, Arizona`}
            class="w-full aspect-[4/5] object-cover object-[center_22%]"
            loading="eager"
            decoding="async"
            width="480"
            height="600"
          />
          <figcaption class="text-[10px] tracking-[0.18em] uppercase text-muted-foreground pt-[var(--space-xs)] text-center">
            {siteConfig.location}
          </figcaption>
        </figure>
      </div>

      <div class="accent-line mt-[var(--space-xl)]! mb-0!" aria-hidden="true"></div>
    </section>

    <section class="text-band pt-[var(--space-md)]! space-y-[var(--space-md)]">
      <p class="prose-measure text-base leading-relaxed text-foreground">
        {siteConfig.about}
      </p>

      <p class="prose-measure text-base leading-relaxed text-foreground">
        Recent work:
        <a href="https://github.com/cloudflare/vinext" class="text-primary link-underline-grow" rel="noopener">Vinext</a>
        at <a href="https://www.cloudflare.com" class="text-primary link-underline-grow" rel="noopener noreferrer">Cloudflare</a> (running Next.js on Vite for Workers),
        <a href="https://github.com/Divkix/Logwell" class="text-primary link-underline-grow" rel="noopener">LogWell</a>
        for self-hosted logging,
        <a href="https://pickmyclass.app" class="text-primary link-underline-grow" rel="noopener">PickMyClass</a>
        for ASU course alerts,
        <a href="https://clickfolio.me" class="text-primary link-underline-grow" rel="noopener">Clickfolio</a>
        for AI portfolios on Workers, and
        <a href="https://github.com/Divkix/Alita_Robot" class="text-primary link-underline-grow" rel="noopener">Alita Robot</a>
        for Telegram communities ({siteConfig.facts.impact} users).
      </p>

      <p class="prose-measure text-base leading-relaxed text-foreground">
        Day-to-day I work in TypeScript, Go, and Python. Mostly Cloudflare Workers, PostgreSQL, Docker, and edge-native architectures. I like clean APIs, boring reliability, and software people open more than once.
      </p>
    </section>

    <section class="text-band pt-[var(--space-md)]! space-y-[var(--space-lg)]">
      <div class="space-y-[var(--space-xs)]">
        <h2 class="font-display text-[length:var(--text-xl)] leading-tight text-foreground m-0">
          Outside of code
        </h2>
        <p class="prose-measure text-base leading-relaxed text-muted-foreground">
          {siteConfig.interests}
        </p>
      </div>

      <div class="space-y-[var(--space-xs)]">
        <h2 class="font-display text-[length:var(--text-xl)] leading-tight text-foreground m-0">
          Open to work
        </h2>
        <p class="prose-measure text-base leading-relaxed text-foreground">
          Full-time software engineering roles starting May 2026: backend, infrastructure, developer tools, AI tooling. Open to relocation. Remote-friendly.
        </p>
      </div>

      <div class="pt-[var(--space-xs)]">
        <SocialIcons size="sm" />
      </div>
    </section>

    <div class="text-band pt-[var(--space-md)]!">
      <hr class="hairline-rule mb-[var(--space-xl)]" />
      <ExperienceBentoStatic />
    </div>

    <div class="text-band pt-[var(--space-md)]! pb-[var(--space-3xl)]">
      <Skills client:visible />
    </div>
  </article>
</SiteLayout>
