---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { siteConfig } from "@/data/site.config";
import BlogLayout from "@/layouts/BlogLayout.astro";
import {
  generateBlogAuthorSchema,
  generateBlogPublisherSchema,
  generateBreadcrumbSchema,
  generateFAQPageSchema,
  generateHowToSchema,
  generateReviewedBySchema,
  generateSpeakableSchema,
  getJobTitle,
} from "@/lib/schema";
import { baseUrl } from "@/lib/seo";
import { calculateReadingTime, formatDate } from "@/lib/utils";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post: CollectionEntry<"blog">) => post.data.published === true)
    .map((post: CollectionEntry<"blog">) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

interface Heading {
  slug: string;
  text: string;
  depth: number;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Get all posts for related posts section
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter(
    (p: CollectionEntry<"blog">) =>
      p.id !== post.id &&
      p.data.published === true &&
      p.data.tags.some((tag: string) => post.data.tags.includes(tag)),
  )
  .slice(0, 3);

const readingTimeMinutes = calculateReadingTime(post.body);
const readingTime = `${readingTimeMinutes} min read`;
const wordCount = post.body.trim().split(/\s+/).length;

const toc = headings.map((h: Heading) => ({
  id: h.slug,
  text: h.text,
  level: h.depth,
}));

const showToc = toc.length >= 3;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${baseUrl}/blog/${post.id}/#article`,
  headline: post.data.title,
  description: post.data.excerpt,
  url: `${baseUrl}/blog/${post.id}/`,
  datePublished: `${post.data.date}T00:00:00Z`,
  dateModified: post.data.dateModified
    ? `${post.data.dateModified}T00:00:00Z`
    : `${post.data.date}T00:00:00Z`,
  author: generateBlogAuthorSchema(post.data.author),
  publisher: generateBlogPublisherSchema(),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${baseUrl}/blog/${post.id}/`,
  },
  image: `${baseUrl}/og/blog/${post.id}.png`,
  keywords: post.data.tags.join(", "),
  articleSection: post.data.tags[0] ?? "Technology",
  wordCount: wordCount,
  timeRequired: `PT${readingTimeMinutes}M`,
  inLanguage: "en-US",
  ...(post.data.reviewedBy
    ? {
        reviewedBy: generateReviewedBySchema(post.data.reviewedBy),
      }
    : {}),
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "Blog", item: `${baseUrl}/blog/` },
  { name: post.data.title, item: `${baseUrl}/blog/${post.id}/` },
]);

const postUrl = `${baseUrl}/blog/${post.id}/`;
const articleId = `${postUrl}#article`;

// Speakable schema - targets TL;DR and key takeaways for voice assistants
const speakableSchema = generateSpeakableSchema(
  articleId,
  "#speakable-content",
);

// FAQPage schema - only if post has FAQ data
const faqPageSchema =
  post.data.faq && post.data.faq.length > 0
    ? generateFAQPageSchema(post.data.faq, postUrl)
    : null;

// seoTitle/seoDescription allow per-post SEO overrides without changing the visible h1
const pageTitle = post.data.seoTitle ?? post.data.title;
const pageDescription = post.data.seoDescription ?? post.data.excerpt;
const ogImage = `${baseUrl}/og/blog/${post.id}.png`;

const articleMeta = {
  publishedTime: `${post.data.date}T00:00:00Z`,
  author: post.data.author,
  tags: post.data.tags,
  wordCount: wordCount,
  articleSection: post.data.tags[0] ?? "Technology",
  ...(post.data.dateModified
    ? { modifiedTime: `${post.data.dateModified}T00:00:00Z` }
    : {}),
};

// HowTo schema - only for posts with tutorial steps
const howToSchema =
  post.data.howToSteps && post.data.howToSteps.length > 0
    ? generateHowToSchema(
        post.data.title,
        post.data.excerpt,
        post.data.howToSteps,
        `PT${readingTimeMinutes}M`,
      )
    : null;
---

<BlogLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
  showReadingProgress={true}
  readingTime={readingTimeMinutes}
  ogType="article"
  articleMeta={articleMeta}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Speakable Schema - identifies content for voice assistants -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />

  {howToSchema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  )}

  {faqPageSchema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />
  )}

  <!-- Table of Contents - Fixed sidebar on xl screens, mobile toggle below -->
  {showToc && (
    <>
      {/* Mobile TOC Toggle */}
      <div class="xl:hidden container mx-auto px-4 pt-4">
        <details class="glass-surface rounded-lg border border-border/40">
          <summary class="p-4 cursor-pointer font-semibold flex items-center justify-between">
            <span>Table of Contents</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </summary>
          <nav class="p-4 pt-0 space-y-2 text-sm">
            <ul class="space-y-2">
              {toc.map((item: { id: string; text: string; level: number }) => (
                <li style={`padding-left: ${(item.level - 1) * 0.75}rem`}>
                  <a
                    href={`#${item.id}`}
                    class="text-foreground/60 hover:text-primary transition-colors"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </details>
      </div>

      {/* Desktop TOC - Fixed sidebar */}
      <aside class="hidden xl:block fixed top-24 left-8 w-64 max-h-[calc(100vh-8rem)] overflow-y-auto">
        <nav class="space-y-2 text-sm">
          <h3 class="font-semibold mb-4">Table of Contents</h3>
          <ul class="space-y-2">
            {toc.map((item: { id: string; text: string; level: number }) => (
              <li style={`padding-left: ${(item.level - 1) * 0.75}rem`}>
                <a
                  href={`#${item.id}`}
                  class="text-foreground/60 hover:text-primary transition-colors"
                >
                  {item.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    </>
  )}

  <article id="main-content" class="container mx-auto px-4 py-20">
    <div class="max-w-3xl mx-auto space-y-8">
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 text-foreground/60 hover:text-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7" />
          <path d="M19 12H5" />
        </svg>
        Back to Blog
      </a>

      <header class="space-y-4">
        <h1 class="text-5xl font-display font-bold">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-4 text-foreground/60">
          <span class="text-sm px-3 py-1 bg-secondary text-secondary-foreground rounded">
            {readingTime}
          </span>
          <time datetime={post.data.date}>
            Published {formatDate(post.data.date)}
          </time>
          {post.data.dateModified && (
            <>
              <span class="text-primary" aria-hidden="true">•</span>
              <time datetime={post.data.dateModified} class="text-primary font-medium">
                Updated {formatDate(post.data.dateModified)}
              </time>
            </>
          )}
          <address class="not-italic">
            by <a href="/divkix" class="hover:text-primary"><span>{post.data.author}</span></a>
          </address>
        </div>

        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <a
                href={`/blog/tags/${tag.toLowerCase()}/`}
                class="text-xs px-2 py-1 border border-border/60 rounded hover:border-primary/60 hover:text-primary transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <img
        src={`/og/blog/${post.id}.webp`}
        srcset={`/og/blog/${post.id}-480.webp 480w, /og/blog/${post.id}-768.webp 768w, /og/blog/${post.id}.webp 1200w`}
        sizes="(max-width: 480px) 480px, (max-width: 768px) 768px, 1200px"
        alt={`Featured image for ${post.data.title}`}
        width="1200"
        height="630"
        class="w-full rounded-lg"
        loading="eager"
        decoding="async"
      />

      {(post.data.tldr || (post.data.keyTakeaways && post.data.keyTakeaways.length > 0)) && (
        <div id="speakable-content" class="space-y-6">
          {post.data.tldr && (
            <div class="tldr-summary glass-surface p-6 rounded-lg border-l-4 border-primary">
              <h2 class="text-lg font-semibold mb-2">TL;DR</h2>
              <p class="text-foreground/70">{post.data.tldr}</p>
            </div>
          )}

          {post.data.keyTakeaways && post.data.keyTakeaways.length > 0 && (
            <div class="key-takeaways glass-surface p-6 rounded-lg">
              <h2 class="text-lg font-semibold mb-4">Key Takeaways</h2>
              <ul class="key-takeaways-list space-y-2">
                {post.data.keyTakeaways.map((takeaway: string) => (
                  <li class="flex items-start gap-2">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-primary shrink-0 mt-0.5"
                      aria-hidden="true"
                    >
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                    <span class="text-foreground/70">{takeaway}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      <div class="prose prose-slate dark:prose-invert max-w-none prose-headings:scroll-mt-20">
        <Content />
      </div>

      {post.data.faq && post.data.faq.length > 0 && (
        <section id="faq" class="space-y-6" aria-labelledby="faq-heading">
          <h2 id="faq-heading" class="text-2xl font-bold">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {post.data.faq.map((faq: { q: string; a: string }) => (
              <div class="glass-surface p-6 rounded-lg">
                <h3 class="font-semibold text-lg">{faq.q}</h3>
                <p class="mt-3 text-foreground/70">{faq.a}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {post.data.sources && post.data.sources.length > 0 && (
        <section class="pt-8 border-t border-border/40" aria-labelledby="sources-heading">
          <h2 id="sources-heading" class="text-2xl font-bold mb-4">Sources & References</h2>
          <ul class="space-y-2">
            {post.data.sources.map((source: string) => (
              <li>
                <a
                  href={source}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline break-all"
                >
                  {source}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {relatedPosts.length > 0 && (
        <section class="pt-8 border-t border-border/40" aria-labelledby="related-posts-heading">
          <h2 id="related-posts-heading" class="text-2xl font-bold mb-6">Related Posts</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {relatedPosts.map((relatedPost: CollectionEntry<"blog">) => (
              <a
                href={`/blog/${relatedPost.id}/`}
                class="block glass-surface hover:border-primary/50 transition-colors rounded-lg overflow-hidden border border-border/40 p-4"
              >
                <h3 class="font-semibold hover:text-primary transition-colors mb-2">
                  {relatedPost.data.title}
                </h3>
                <p class="text-sm text-foreground/60 line-clamp-2">
                  {relatedPost.data.excerpt}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="pt-8 border-t border-border/40">
        <div class="glass-surface p-6 rounded-lg">
          <div class="flex gap-4 items-start">
            <img
              src="/divanshu-chauhan.webp"
              alt="Divanshu Chauhan"
              class="w-16 h-16 rounded-full"
              loading="lazy"
            />
            <div class="flex-1">
              <h3 class="font-semibold">
                {post.data.author}
                <span class="text-foreground/50 font-normal">(@{siteConfig.handle.toLowerCase()})</span>
              </h3>
              <p class="text-sm text-foreground/70 mt-1">
                {getJobTitle()} & MS CS @ Arizona State University. Currently SWE Intern @ Cloudflare. Based in {siteConfig.location}.
              </p>
              <p class="text-sm text-foreground/60 mt-2">
                Expertise:
                {post.data.tags.slice(0, 4).join(", ")}.
                <a href="/about" class="underline hover:text-primary ml-1">More about {siteConfig.handle.toLowerCase()}</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>
</BlogLayout>
