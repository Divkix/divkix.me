---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import { generateBreadcrumbSchema } from "@/lib/schema";
import { baseUrl } from "@/lib/seo";
import { calculateReadingTime, formatDate } from "@/lib/utils";

const allPosts = await getCollection("blog");

const featuredSlugs = [
  {
    slug: "clickfolio-full-stack-cloudflare-workers",
    title: "Building Clickfolio — A Full-Stack App on Cloudflare Workers",
    description:
      "How I built an AI-powered portfolio generator using Workers, D1, R2, Queues, Durable Objects, and WebSockets.",
  },
  {
    slug: "logwell-self-hosted-logging-platform",
    title: "LogWell — Building a Self-Hosted Logging Platform",
    description:
      "Real-time log streaming, OTLP-compatible ingestion, and PostgreSQL full-text search — without running a giant observability stack.",
  },
  {
    slug: "scaling-telegram-bot-300k-users",
    title: "Scaling a Telegram Bot to 300K+ Users",
    description:
      "Lessons from building and scaling Alita Robot, a community automation bot used by large public Telegram groups.",
  },
  {
    slug: "ai-models-compared-2026",
    title: "AI Models Compared: 2026 Edition",
    description:
      "A practical comparison of current AI models — what's good, what's not, and what I'd actually use for real work. Last updated April 2026.",
  },
];

const featuredPosts = featuredSlugs
  .map((f) => {
    const post = allPosts.find((p: CollectionEntry<"blog">) => p.id === f.slug);
    if (!post) return null;
    return {
      ...f,
      post,
      readingTime: `${calculateReadingTime(post.body)} min read`,
    };
  })
  .filter((f): f is NonNullable<typeof f> => f !== null);

const posts = allPosts
  .filter((post: CollectionEntry<"blog">) => post.data.published === true)
  .sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  });

type PostWithReadingTime = {
  post: CollectionEntry<"blog">;
  readingTime: string;
};

const postsWithReadingTime: PostWithReadingTime[] = posts.map(
  (post: CollectionEntry<"blog">) => ({
    post,
    readingTime: `${calculateReadingTime(post.body)} min read`,
  }),
);

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${baseUrl}/blog/`,
  name: "Blog",
  description:
    "Thoughts on software development, technology, and building products.",
  url: `${baseUrl}/blog/`,
  isPartOf: { "@type": "WebSite", "@id": `${baseUrl}/#website` },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: posts.map(
      (post: CollectionEntry<"blog">, index: number) => ({
        "@type": "ListItem",
        position: index + 1,
        url: `${baseUrl}/blog/${post.id}/`,
        name: post.data.title,
      }),
    ),
  },
};

const blogBreadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "Blog", item: `${baseUrl}/blog/` },
]);
---

<BlogLayout
  title="Blog"
  description="Thoughts on software development, technology, and building products."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(collectionPageSchema)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(blogBreadcrumbSchema)}
  />
  <div class="container mx-auto px-4 py-20">
    <div class="max-w-4xl mx-auto space-y-12">
      <div class="space-y-4">
        <h1 class="text-5xl font-display font-bold">Blog</h1>
        <p class="text-xl text-foreground/70">
          Thoughts on software development, technology, and building products.
        </p>
      </div>

      {
        featuredPosts.length > 0 && (
          <section class="space-y-6">
            <div>
              <h2 class="text-2xl font-bold mb-2">Start here</h2>
              <p class="text-muted-foreground">
                The best posts if you want to understand how I think about
                systems, product tradeoffs, and shipping real software.
              </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {featuredPosts.map((item) => (
                <a
                  href={`/blog/${item.slug}/`}
                  class="block transition-all hover:scale-[1.01]"
                >
                  <article class="glass-surface hover:border-primary/50 transition-colors rounded-lg overflow-hidden border border-border/40 h-full">
                    <div class="p-6 space-y-4">
                      <div class="flex items-center justify-between gap-4 flex-wrap">
                        <span class="text-sm px-3 py-1 bg-secondary text-secondary-foreground rounded">
                          {item.readingTime}
                        </span>
                        <time
                          datetime={item.post.data.date}
                          class="text-sm text-foreground/60"
                        >
                          {formatDate(item.post.data.date)}
                        </time>
                      </div>
                      <h3 class="text-xl font-bold hover:text-primary transition-colors">
                        {item.title}
                      </h3>
                      <p class="text-base text-foreground/70">
                        {item.description}
                      </p>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        posts.length === 0 ? (
          <p class="text-foreground/60">No posts yet. Check back soon!</p>
        ) : (
          <div>
            <h2 class="text-2xl font-bold mb-6">All posts</h2>
            <div class="space-y-6">
              {postsWithReadingTime.map((item: PostWithReadingTime) => (
                <a
                  href={`/blog/${item.post.id}/`}
                  class="block transition-all hover:scale-[1.01]"
                >
                  <article class="glass-surface hover:border-primary/50 transition-colors rounded-lg overflow-hidden border border-border/40">
                    <div class="p-6 space-y-4">
                      <div class="flex items-center justify-between gap-4 flex-wrap">
                        <div class="flex items-center gap-2">
                          {item.post.data.featured && (
                            <span class="text-xs px-2 py-0.5 bg-primary/10 text-primary border border-primary/20 rounded font-medium">
                              Featured
                            </span>
                          )}
                          <span class="text-sm px-3 py-1 bg-secondary text-secondary-foreground rounded">
                            {item.readingTime}
                          </span>
                        </div>
                        <time
                          datetime={item.post.data.date}
                          class="text-sm text-foreground/60"
                        >
                          {formatDate(item.post.data.date)}
                        </time>
                      </div>
                      <h3 class="text-2xl font-bold hover:text-primary transition-colors">
                        {item.post.data.title}
                      </h3>
                      {item.post.data.excerpt && (
                        <p class="text-base text-foreground/70">
                          {item.post.data.excerpt}
                        </p>
                      )}
                      {item.post.data.tags.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {item.post.data.tags.map((tag: string) => (
                            <a
                              href={`/blog/tags/${tag.toLowerCase()}/`}
                              class="text-xs px-2 py-1 border border-border/60 rounded hover:border-primary/60 hover:text-primary transition-colors"
                            >
                              {tag}
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                  </article>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>
</BlogLayout>
