---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import { generateBreadcrumbSchema, generateFAQPageSchema } from "@/lib/schema";
import { baseUrl } from "@/lib/seo";
import { calculateReadingTime, formatDate } from "@/lib/utils";

const allPosts = await getCollection("blog");

const posts = allPosts
  .filter((post: CollectionEntry<"blog">) => post.data.published === true)
  .sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  });

type PostWithReadingTime = {
  post: CollectionEntry<"blog">;
  readingTime: string;
};

const postsWithReadingTime: PostWithReadingTime[] = posts.map(
  (post: CollectionEntry<"blog">) => ({
    post,
    readingTime: `${calculateReadingTime(post.body)} min read`,
  }),
);

const blogUrl = `${baseUrl}/blog`;

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": blogUrl,
  name: "Blog | Divanshu Chauhan — Software Engineering & Building in Public",
  description:
    "Technical blog on software engineering, AI tooling, Cloudflare Workers, developer tools, and building production systems.",
  url: blogUrl,
  isPartOf: { "@type": "WebSite", "@id": `${baseUrl}/#website` },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: posts.map(
      (post: CollectionEntry<"blog">, index: number) => ({
        "@type": "ListItem",
        position: index + 1,
        url: `${baseUrl}/blog/${post.id}`,
        name: post.data.title,
      }),
    ),
  },
};

const blogBreadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "Blog", item: blogUrl },
]);

const blogFaqSchema = generateFAQPageSchema(
  [
    {
      q: "What does Divanshu Chauhan write about?",
      a: "Posts cover software engineering, Cloudflare Workers, developer tools, AI-assisted development, observability, Telegram bot scaling, and lessons from shipping side projects.",
    },
    {
      q: "Who writes the divkix.me blog?",
      a: "All posts are written by Divanshu Chauhan (divkix), a software engineer at Cloudflare with an MS in Computer Science from ASU (GPA 3.889). He contributes to Vinext and builds tools like LogWell and Clickfolio.",
    },
  ],
  blogUrl,
);
---

<BlogLayout
  title="Blog | Divanshu Chauhan — Software Engineering & Building in Public"
  description="Notes on building products, scaling systems, and the tools I actually use. By Divanshu Chauhan (divkix), Cloudflare engineer and Vinext contributor."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(collectionPageSchema)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(blogBreadcrumbSchema)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(blogFaqSchema)}
  />
  <div class="container mx-auto px-4 py-20">
    <div class="max-w-3xl mx-auto space-y-12">
      <header class="space-y-4 border-b border-border pb-10">
        <h1 class="font-display text-4xl md:text-5xl font-medium tracking-tight">Writing</h1>
        <p class="text-xl text-muted-foreground leading-relaxed max-w-prose">
          Notes on building products, scaling systems, and the tools I reach for when something breaks at 2am.
        </p>
      </header>

      {
        posts.length === 0 ? (
          <p class="text-muted-foreground">No posts yet. Check back soon.</p>
        ) : (
          <ol class="list-none m-0 p-0 space-y-0">
            {postsWithReadingTime.map((item: PostWithReadingTime) => (
              <li class="border-t border-border py-8 first:border-t-0 first:pt-0">
                <article class="space-y-3">
                  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 text-sm text-muted-foreground">
                    <time datetime={item.post.data.date} class="tabular-nums">
                      {formatDate(item.post.data.date)}
                    </time>
                    <span>{item.readingTime}</span>
                  </div>
                  <h2 class="font-display text-2xl md:text-3xl font-medium leading-snug">
                    <a
                      href={`/blog/${item.post.id}`}
                      class="text-foreground hover:text-primary transition-colors link-underline-grow"
                    >
                      {item.post.data.title}
                    </a>
                  </h2>
                  {item.post.data.excerpt && (
                    <p class="text-base text-muted-foreground leading-relaxed">
                      {item.post.data.excerpt}
                    </p>
                  )}
                  {item.post.data.tags.length > 0 && (
                    <p class="text-sm text-muted-foreground">
                      {item.post.data.tags.map((tag: string) => (
                        <a
                          href={`/blog/tags/${tag.toLowerCase()}`}
                          class="hover:text-primary transition-colors link-underline-grow mr-2 last:mr-0"
                        >
                          {tag}
                        </a>
                      ))}
                    </p>
                  )}
                </article>
              </li>
            ))}
          </ol>
        )
      }
    </div>
  </div>
</BlogLayout>
