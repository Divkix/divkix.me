---
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout
  title="404 - Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex
>
  <div class="text-band">
    <div class="text-center space-y-8">
      <div class="space-y-4">
        <h1 class="font-display text-(length:--text-display) leading-[1.02] text-primary">404</h1>
        <h2 class="font-display text-(length:--text-2xl) leading-[1.1]">Page not found</h2>
        <p class="text-(length:--text-lg) text-muted-foreground max-w-prose mx-auto">
          The page you're looking for doesn't exist or may have moved.
        </p>
      </div>

      <div class="surface-raised p-8 space-y-6 max-w-md mx-auto">
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center whitespace-nowrap px-6 py-3 bg-primary text-primary-foreground rounded-(--radius-input) hover:bg-primary/90 transition-colors"
          >
            Go home
          </a>
          <a
            href="/blog"
            class="inline-flex items-center justify-center whitespace-nowrap px-6 py-3 border border-border rounded-(--radius-input) hover:border-primary transition-colors"
          >
            Read the blog
          </a>
        </div>
      </div>

      <p class="text-(length:--text-sm) text-muted-foreground">
        If you believe this is a mistake, please{" "}
        <a href="/#contact" class="text-primary link-underline-grow">
          get in touch
        </a>
        .
      </p>
    </div>
  </div>
</SiteLayout>
