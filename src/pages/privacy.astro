---
import { siteConfig } from "@/data/site.config";
import SiteLayout from "@/layouts/SiteLayout.astro";
import {
  generateBreadcrumbSchema,
  generateFAQPageSchema,
  generateProfilePageSchema,
} from "@/lib/schema";
import { baseUrl } from "@/lib/seo";

const faqPageSchema = generateFAQPageSchema(
  [
    {
      q: "What data do you collect?",
      a: "I collect minimal data: contact form submissions, basic analytics, and theme preferences.",
    },
    {
      q: "How do you protect my information?",
      a: "I use reasonable security measures and do not sell or trade personal information.",
    },
    {
      q: "Who processes my contact form submissions?",
      a: "Formspree processes contact form submissions. You can review their privacy policy.",
    },
  ],
  `${baseUrl}/privacy`,
);

const lastUpdated = "May 20, 2026";

const privacyPageSchema = generateProfilePageSchema(
  "Privacy Policy",
  `Privacy Policy for ${siteConfig.name}'s portfolio website`,
  `${baseUrl}/privacy`,
  {
    datePublished: "2025-01-01",
    articleSection: "Legal",
  },
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "Privacy", item: `${baseUrl}/privacy` },
]);
---

<SiteLayout
  title="Privacy Policy"
  description={`Privacy Policy for ${siteConfig.name}'s portfolio website`}
  ogImage={`${baseUrl}/og/privacy.png`}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(privacyPageSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />

  <div class="text-band">
    <div class="space-y-(--space-xl)">
      <div class="space-y-(--space-md)">
        <p class="mast-line">Legal</p>
        <h1 class="font-display text-(length:--text-display-s)">Privacy Policy</h1>
        <p class="text-muted-foreground">Last updated: {lastUpdated}</p>
      </div>

      <div class="prose prose-slate dark:prose-invert max-w-none">
        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Overview</h2>
          <p class="text-foreground/80">
            This privacy policy describes how {siteConfig.name} ("I", "me", "my")
            collects, uses, and protects information on this website (divkix.me).
          </p>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Information Collection</h2>
          <p class="text-foreground/80">
            This website is built with privacy in mind and collects minimal information:
          </p>
          <ul class="list-disc list-inside space-y-(--space-xs) text-foreground/80">
            <li>
              <strong>Contact Form:</strong> When you submit the contact form, I collect
              your name, email address, and message content to respond to your inquiry.
            </li>
            <li>
              <strong>Analytics:</strong> This site may use privacy-respecting analytics
              to understand visitor patterns without tracking personal information.
            </li>
            <li>
              <strong>Cookies:</strong> This site uses minimal cookies, primarily for
              theme preferences (dark/light mode).
            </li>
          </ul>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">How Information is Used</h2>
          <p class="text-foreground/80">
            Information collected is used solely for:
          </p>
          <ul class="list-disc list-inside space-y-(--space-xs) text-foreground/80">
            <li>Responding to contact form submissions</li>
            <li>Improving website content and user experience</li>
            <li>Remembering user preferences (theme settings)</li>
          </ul>
          <p class="text-foreground/80">
            I do not sell or trade your personal information. Personal data is not
            shared with third parties except with service providers and processors
            required to operate this site (such as Formspree for the contact form;
            see Third-Party Services below).
          </p>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Data Security</h2>
          <p class="text-foreground/80">
            I implement reasonable security measures to protect your information.
            However, no method of transmission over the internet is 100% secure.
          </p>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Third-Party Services</h2>
          <p class="text-foreground/80">
            This website is hosted on Cloudflare Workers. Please refer to
            <a
              href="https://www.cloudflare.com/privacypolicy/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary link-underline-grow"
            >
              Cloudflare's Privacy Policy
            </a>
            for information about their data handling practices.
          </p>
          <p class="text-foreground/80">
            As one such processor, the contact form uses Formspree to process and deliver your messages. When you submit a message, your name, email, and message content are transmitted to and processed by Formspree. You can review their data handling practices in the
            <a
              href="https://formspree.io/privacy"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary link-underline-grow"
            >
              Formspree Privacy Policy
            </a>.
          </p>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Your Rights</h2>
          <p class="text-foreground/80">You have the right to:</p>
          <ul class="list-disc list-inside space-y-(--space-xs) text-foreground/80">
            <li>Request access to information I have collected</li>
            <li>Request deletion of your information</li>
            <li>Opt-out of any data collection</li>
          </ul>
          <p class="text-foreground/80">
            To exercise these rights, contact me at{" "}
            <a
              href={`mailto:${siteConfig.email}`}
              class="text-primary link-underline-grow"
            >
              {siteConfig.email}
            </a>
          </p>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Children's Privacy</h2>
          <p class="text-foreground/80">
            This website is not intended for children under 13 years of age.
            I do not knowingly collect information from children under 13.
          </p>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Changes to This Policy</h2>
          <p class="text-foreground/80">
            I may update this privacy policy from time to time. Changes will be posted
            on this page with an updated "Last updated" date.
          </p>
        </section>

        <section class="surface-raised p-8 space-y-(--space-md)">
          <h2 class="font-display text-(length:--text-xl)">Contact</h2>
          <p class="text-foreground/80">
            If you have questions about this privacy policy, please contact me at:
          </p>
          <ul class="list-none space-y-(--space-xs) text-foreground/80">
            <li>
              Email:{" "}
              <a
                href={`mailto:${siteConfig.email}`}
                class="text-primary link-underline-grow"
              >
                {siteConfig.email}
              </a>
            </li>
            <li>Website: <a href="/" class="text-primary link-underline-grow">divkix.me</a></li>
          </ul>
        </section>
      </div>
    </div>
  </div>
</SiteLayout>
