---
import { NOINDEX_PATHS, siteConfig } from "@/data/site.config";
import SiteLayout from "@/layouts/SiteLayout.astro";

const noindex = NOINDEX_PATHS.includes("/mentions");

import {
  generateBreadcrumbSchema,
  generateFAQPageSchema,
  generateProfilePageSchema,
} from "@/lib/schema";
import { baseUrl } from "@/lib/seo";

const faqPageSchema = generateFAQPageSchema(
  [
    {
      q: "What is this page for?",
      a: "This page tracks external citations, podcast appearances, and conference talks featuring me.",
    },
    {
      q: "Are there any mentions yet?",
      a: "No external mentions have been recorded yet. Check back for updates.",
    },
  ],
  `${baseUrl}/mentions`,
);

const mentionsPageSchema = generateProfilePageSchema(
  `Mentions & Press — ${siteConfig.name}`,
  `External citations, podcast appearances, and conference talks featuring ${siteConfig.name}.`,
  `${baseUrl}/mentions`,
  {
    datePublished: "2025-01-01",
    articleSection: "Mentions",
  },
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
  { name: "Mentions", item: `${baseUrl}/mentions` },
]);
---

<SiteLayout
  title={`Mentions & Press — ${siteConfig.name} (${siteConfig.handle.toLowerCase()})`}
  description={`External citations, podcast appearances, and conference talks featuring ${siteConfig.name} (divkix).`}
  ogImage={`${baseUrl}/og/mentions.png`}
  noindex={noindex}
>
  <!--
    These schema scripts (mentionsPageSchema, breadcrumbSchema, faqPageSchema)
    are wrapped to only render when the page is indexable. They serve as
    scaffolding for future indexed content.
  -->
  {!noindex && (
    <>
      <script is:inline type="application/ld+json" set:html={JSON.stringify(mentionsPageSchema)} />
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />
    </>
  )}

  <div class="text-band">
    <div class="space-y-12">
      <div class="space-y-4">
        <p class="mast-line">Mentions</p>
        <h1 class="font-display text-[length:var(--text-display)]">Mentions & Press</h1>
        <p class="text-xl text-foreground/70">
          External citations, podcast appearances, and conference talks.
        </p>
      </div>

      <div class="surface-raised p-8 rounded-none">
        <p class="text-foreground/70 leading-relaxed">
          This page tracks where {siteConfig.name} has been cited, referenced, or featured across the web.
          As coverage grows, it will be updated with links to podcasts, conference talks, and external publications.
        </p>
      </div>

      <div class="border border-border/40 rounded-none p-8 text-center">
        <p class="text-foreground/60">
          No external mentions recorded yet. Check back for updates.
        </p>
      </div>
    </div>
  </div>
</SiteLayout>
