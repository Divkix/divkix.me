---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { ContactWithBoundary } from "@/components/sections/Contact";
import Hero from "@/components/sections/Hero.astro";
import { HighlightsWithBoundary } from "@/components/sections/Highlights";
import { Projects } from "@/components/sections/Projects";
import RecentWriting from "@/components/sections/RecentWriting.astro";
import { siteConfig } from "@/data/site.config";
import SiteLayout from "@/layouts/SiteLayout.astro";
import {
  generateBreadcrumbSchema,
  generateCollectionPageSchema,
  generateFAQPageSchema,
} from "@/lib/schema";
import { baseUrl } from "@/lib/seo";

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .filter((post: CollectionEntry<"blog">) => post.data.published === true)
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 3);

const collectionPageSchema = generateCollectionPageSchema(
  `${siteConfig.name} — Software Engineer & Builder`,
  siteConfig.seo.metaDescription,
  baseUrl,
  {
    datePublished: "2025-01-01",
    dateModified: "2026-05-20",
    articleSection: "Portfolio",
  },
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
]);

const homeFaqSchema = generateFAQPageSchema([...siteConfig.faq], baseUrl);
---

<SiteLayout showScrollProgress={true} ogImage={`${baseUrl}/og/blog.png`} dateModified="2026-05-20">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(homeFaqSchema)} />
  <Hero />
  <HighlightsWithBoundary client:visible />
  <RecentWriting posts={recentPosts} />
  <Projects client:visible />
  <ContactWithBoundary client:visible />
</SiteLayout>
