---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { ContactWithBoundary } from "@/components/sections/Contact";
import Hero from "@/components/sections/Hero.astro";
import { HighlightsWithBoundary } from "@/components/sections/Highlights";
import { Projects } from "@/components/sections/Projects";
import RecentWriting from "@/components/sections/RecentWriting.astro";
import { siteConfig } from "@/data/site.config";
import SiteLayout from "@/layouts/SiteLayout.astro";
import {
  generateBreadcrumbSchema,
  generateCollectionPageSchema,
  generateFAQPageSchema,
  generateSoftwareApplicationSchema,
} from "@/lib/schema";
import { baseUrl } from "@/lib/seo";

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .filter((post: CollectionEntry<"blog">) => post.data.published === true)
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 3);

const collectionPageSchema = generateCollectionPageSchema(
  `${siteConfig.name} — Software Engineer & Builder`,
  siteConfig.seo.metaDescription,
  baseUrl,
  {
    datePublished: "2025-01-01",
    articleSection: "Portfolio",
  },
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: baseUrl },
]);

const homeFaqSchema = generateFAQPageSchema([...siteConfig.faq], baseUrl);

const authorId = `${baseUrl}/#author`;

// Note: only the author's own projects are modelled as SoftwareApplication
// authored by the Person node. Vinext is a Cloudflare project the author
// contributes to (not authors), so it is represented via the Person node's
// knowsAbout entity signal instead — not as an owned SoftwareApplication.
const logwellSchema = generateSoftwareApplicationSchema(
  "LogWell",
  "Self-hosted logging platform",
  "https://github.com/Divkix/Logwell",
  authorId,
  {
    applicationCategory: "DeveloperApplication",
    keywords: ["Logging", "PostgreSQL", "Docker", "OTLP"],
    codeRepository: "https://github.com/Divkix/Logwell",
  },
);

const clickfolioSchema = generateSoftwareApplicationSchema(
  "Clickfolio",
  "AI portfolio builder on Cloudflare Workers",
  "https://clickfolio.me",
  authorId,
  {
    applicationCategory: "WebApplication",
    keywords: ["AI", "Portfolio", "Cloudflare", "Workers"],
    codeRepository: "https://github.com/Divkix/clickfolio.me",
  },
);

// Assemble a single JSON-LD graph. Each helper returns a standalone node with
// its own "@context"; strip it from members so only the graph wrapper carries
// the context (valid, idiomatic JSON-LD without redundant duplicate contexts).
const graphSchema = {
  "@context": "https://schema.org",
  "@graph": [
    collectionPageSchema,
    breadcrumbSchema,
    homeFaqSchema,
    logwellSchema,
    clickfolioSchema,
  ].map(({ "@context": _context, ...node }) => node),
};
---

<SiteLayout showScrollProgress={true} ogImage={`${baseUrl}/og/blog.png`}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(graphSchema)} />
  <Hero />
  <HighlightsWithBoundary client:visible />
  <Projects client:visible />
  <RecentWriting posts={recentPosts} />
  <ContactWithBoundary client:visible />
</SiteLayout>
