{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Modern portfolio site with Astro v5, TypeScript, and React Islands",
  "repository": {
    "type": "git",
    "url": "https://github.com/divkix/divkix.me.git"
  },
  "author": "Divanshu Chauhan <divkix@divkix.me>",
  "license": "MIT",
  "homepage": "https://divkix.me",
  "bugs": {
    "url": "https://github.com/divkix/divkix.me/issues"
  },
  "keywords": [
    "portfolio",
    "astro",
    "react",
    "typescript",
    "tailwindcss",
    "blog",
    "mdx"
  ],
  "browserslist": [
    "chrome >= 92",
    "edge >= 92",
    "firefox >= 90",
    "safari >= 15",
    "not IE 11",
    "not dead"
  ],
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/generate-posts-metadata.js && node scripts/generate-og-images.js",
    "build": "bun run prebuild && bun run scripts/validate-content.ts && astro build && bun run scripts/submit-indexnow.ts",
    "preview": "astro preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write",
    "type-check": "astro check && tsc --noEmit",
    "format": "biome format --write .",
    "check:citations": "bun run scripts/check-citation-density.ts",
    "audit:seo": "bun run scripts/seo-production-audit.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "biome check --write",
      "biome format --write"
    ]
  },
  "dependencies": {
    "@4hse/astro-llms-txt": "^1.0.5",
    "@astrojs/mdx": "7.0.0",
    "@astrojs/react": "6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/playfair-display": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "7.0.0",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.21.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "sharp": "^0.35.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "knip": "^6.18.0",
    "lint-staged": "^17.0.8",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14"
}
