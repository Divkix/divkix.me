{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Modern portfolio site with Astro v5, TypeScript, and React Islands",
  "repository": {
    "type": "git",
    "url": "https://github.com/divkix/divkix.me.git"
  },
  "author": "Divanshu Chauhan <divkix@divkix.me>",
  "license": "MIT",
  "homepage": "https://divkix.me",
  "bugs": {
    "url": "https://github.com/divkix/divkix.me/issues"
  },
  "keywords": [
    "portfolio",
    "astro",
    "react",
    "typescript",
    "tailwindcss",
    "blog",
    "mdx"
  ],
  "browserslist": [
    "chrome >= 92",
    "edge >= 92",
    "firefox >= 90",
    "safari >= 15",
    "not IE 11",
    "not dead"
  ],
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/generate-posts-metadata.js && node scripts/generate-og-images.js",
    "build": "bun run prebuild && bun run scripts/validate-content.ts && astro build && bun run scripts/submit-indexnow.ts",
    "preview": "astro preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write",
    "type-check": "astro check && tsc --noEmit",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "biome check --write",
      "biome format --write"
    ]
  },
  "dependencies": {
    "@4hse/astro-llms-txt": "^1.0.5",
    "@astrojs/mdx": "5.0.4",
    "@astrojs/react": "5.0.4",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/instrument-serif": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.11.0",
    "mdast-util-to-string": "^4.0.0",
    "postcss": "^8.5.12",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.74.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vfile": "^6.0.3"
  }
}
